@page "/customers/create"
@rendermode InteractiveServer
@using CrmApp.Shared.DTO
@using CrmApp.Client.Services
@inject CustomerApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Create Customer</h3>

<EditForm Model="newCustomer" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-2">
        <label for="firstName">First Name</label>
        <InputText id="firstName" @bind-Value="newCustomer.FirstName" class="form-control" />
        <ValidationMessage For="@(() => newCustomer.FirstName)" />
    </div>

    <div class="mb-2">
        <label for="lastName">Last Name</label>
        <InputText id="lastName" @bind-Value="newCustomer.LastName" class="form-control" />
        <ValidationMessage For="@(() => newCustomer.LastName)" />
    </div>

    <div class="mb-2">
        <label for="email">Email</label>
        <InputText id="email" @bind-Value="newCustomer.Email" class="form-control" />
        <ValidationMessage For="@(() => newCustomer.Email)" />
    </div>

    <div class="mb-2">
        <label for="phone">Phone</label>
        <InputText id="phone" @bind-Value="newCustomer.PhoneNumber" class="form-control" @oninput="FilterNumericOnly" inputmode="numeric" />
        <ValidationMessage For="@(() => newCustomer.PhoneNumber)" />
    </div>

    <div class="mb-2">
        <label for="address">Address</label>
        <InputText id="address" @bind-Value="newCustomer.Address" class="form-control" />
        <ValidationMessage For="@(() => newCustomer.Address)" />
    </div>

    <div class="mb-2">
        <label for="city">City</label>
        <InputText id="city" @bind-Value="newCustomer.City" class="form-control" />
        <ValidationMessage For="@(() => newCustomer.City)" />
    </div>

    <div class="mb-2">
        <label for="state">State</label>
        <InputText id="state" @bind-Value="newCustomer.State" class="form-control" />
        <ValidationMessage For="@(() => newCustomer.State)" />
    </div>

    <div class="mb-2">
        <label for="country">Country</label>
        <InputText id="country" @bind-Value="newCustomer.Country" class="form-control" />
        <ValidationMessage For="@(() => newCustomer.Country)" />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success me-2">Save</button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
    </div>
</EditForm>

@if (errors.Count > 0)
{
    <ul class="text-danger mt-2">
        @foreach (var e in errors)
        {
            <li>@e</li>
        }
    </ul>
}

@code {
    private readonly CreateCustomerRequest newCustomer = new();
    private readonly List<string> errors = new();

    private async Task HandleValidSubmit()
    {
        errors.Clear();

        var resp = await Api.CreateCustomerAsync(newCustomer);
        if (resp == null)
        {
            await JS.InvokeVoidAsync("showAlert", "success", "Success!", "Customer added successfully.");
            
            await Task.Delay(2000);

            Nav.NavigateTo("/customers");
        }
        else
        {
            errors.AddRange(resp.Errors);
        }
    }

    private void FilterNumericOnly(ChangeEventArgs e)
    {
        var input = e.Value?.ToString() ?? string.Empty;
        var filtered = new string(input.Where(char.IsDigit).ToArray());
        if (filtered != newCustomer.PhoneNumber)
        {
            newCustomer.PhoneNumber = filtered;
        }
    }

    private void Cancel() => Nav.NavigateTo("/customers");
}