@page "/customers"
@rendermode InteractiveServer
@using CrmApp.Client.Services
@using CrmApp.Shared.DTO
@inject CustomerApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Customers</h3>

<button class="btn btn-primary mb-3" @onclick="CreateNew">+ Create New</button>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (customers is null || customers.Count == 0)
{
    <p>No customers found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>First</th>
                <th>Last</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in customers)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.FirstName</td>
                    <td>@c.LastName</td>
                    <td>@c.Email</td>
                    <td>
                        <button class="btn btn-info btn-sm me-2" @onclick="() => ViewCustomer(c.Id)">View</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(c)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
            </li>

            @for (int i = 1; i <= TotalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <button class="page-link" @onclick="() => ChangePage(i)">@i</button>
                </li>
            }

            <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
            </li>
        </ul>
    </nav>
}

@code {
    private List<CustomerDto> customers = new();
    private int currentPage = 1;
    private readonly int pageSize = 10;
    private int totalCustomers = 0;

    private int TotalPages => (int)Math.Ceiling((double)totalCustomers / pageSize);

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {

        isLoading = true;
        try
        {
            var result = await Api.GetCustomersPagedAsync(currentPage, pageSize);
            customers = result.Items;
            totalCustomers = result.TotalCount;

        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= TotalPages)
        {
            currentPage = newPage;
            await LoadCustomers();
        }
    }

    private void CreateNew() => Nav.NavigateTo("/customers/create");

    private void ViewCustomer(int id) => Nav.NavigateTo($"/customers/{id}");


    private async Task ConfirmDelete(CustomerDto customer)
    {
        bool confirmed = await JS.InvokeAsync<bool>("showConfirm", "Are you sure?", "This will delete the item.");
        if (confirmed)
        {
            await DeleteCustomer(customer);
        }
        else
        {
            await JS.InvokeVoidAsync("showAlert", "info", "Cancelled", "Nothing was deleted.");
        }
    }


    private async Task DeleteCustomer(CustomerDto customerToDelete)
    {
        if (customerToDelete is not null)
        {
            var response = await Api.DeleteCustomerAsync(customerToDelete.Id);
            if (response == null)
            {
                await JS.InvokeVoidAsync("showAlert", "success", "Success!", "Customer deleted successfully.");

                await LoadCustomers();
            }
            else
            {
                await JS.InvokeVoidAsync("showAlert", "error", "Something went wrong!", "Delete failed.");
            }
        }
    }
}
